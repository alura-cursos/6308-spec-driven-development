    {
      "name": "[US3] Bloqueio de Cancelamento por Status",
      "description": "Tenta cancelar pedidos em PACKING, SHIPPED e DELIVERED — todos devem retornar 422.\n⚠️ Requer endpoint PATCH /api/v1/orders/:id/status (admin) para avançar o status logístico.",
      "item": [

        {
          "name": "PACKING — Deve bloquear",
          "item": [
            {
              "name": "1. Adicionar ao Carrinho e Checkout",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/cart/items",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{tokenA}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
                }
              },
              "event": [{ "listen": "test", "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
            },
            {
              "name": "2. Checkout → capturar orderId_us3a",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/orders",
                "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }]
              },
              "event": [{
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('201', () => pm.response.to.have.status(201));",
                    "const json = pm.response.json();",
                    "pm.collectionVariables.set('orderId_us3a', json.data.id);",
                    "if (json.data.payment) pm.collectionVariables.set('paymentId_us3a', json.data.payment.id);"
                  ]
                }
              }]
            },
            {
              "name": "3. GET /orders — capturar paymentId_us3a",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/orders",
                "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }]
              },
              "event": [{
                "listen": "test",
                "script": {
                  "exec": [
                    "const orderId = pm.collectionVariables.get('orderId_us3a');",
                    "const order = pm.response.json().data.find(o => o.id === orderId);",
                    "if (order && order.payment) pm.collectionVariables.set('paymentId_us3a', order.payment.id);"
                  ]
                }
              }]
            },
            {
              "name": "4. Confirmar Pagamento",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/payments/{{paymentId_us3a}}/confirm",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{tokenA}}" },
                  { "key": "Idempotency-Key", "value": "us3a-confirm-{{$timestamp}}" }
                ]
              },
              "event": [{ "listen": "test", "script": { "exec": ["pm.test('200', () => pm.response.to.have.status(200));"] } }]
            },
            {
              "name": "5. [ADMIN] Avançar Status para PACKING",
              "request": {
                "method": "PATCH",
                "url": "{{baseUrl}}/orders/{{orderId_us3a}}/status",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"PACKING\"\n}"
                }
              },
              "event": [{
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Avançar para PACKING retorna 200', () => pm.response.to.have.status(200));",
                    "// ⚠️ Se falhar: PATCH /orders/:id/status ainda não está implementado"
                  ]
                }
              }]
            },
            {
              "name": "6. ⭐ Tentar Cancelar Pedido PACKING — espera 422",
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/orders/{{orderId_us3a}}/cancel",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{tokenA}}" }
                ]
              },
              "event": [{
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('[SC-002] Retorna 422 para pedido PACKING', () => pm.response.to.have.status(422));",
                    "",
                    "const json = pm.response.json();",
                    "pm.test('[SC-002] Body contém code ORDER_CANNOT_BE_CANCELED', () => {",
                    "  pm.expect(json.error.code).to.eql('ORDER_CANNOT_BE_CANCELED');",
                    "});"
                  ]
                }
