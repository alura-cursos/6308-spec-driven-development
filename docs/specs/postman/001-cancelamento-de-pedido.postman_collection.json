{
  "info": {
    "name": "001 - Cancelamento de Pedido",
    "description": "Testes de caixa preta para a feature de cancelamento de pedido (spec 001).\n\nPré-requisitos:\n- Servidor rodando em http://localhost:3000\n- Banco de dados com ao menos 1 produto ACTIVE com stock >= 5\n- A rota PATCH /api/v1/orders/:id/status (admin) deve existir para os testes de US3\n\nExecutar as pastas na ordem: [Setup] → [US1] → [US2] → [US3] → [US4] → [US5] → [Edge Cases]",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "tokenA",     "value": "", "type": "string" },
    { "key": "tokenB",     "value": "", "type": "string" },
    { "key": "tokenAdmin", "value": "", "type": "string" },
    { "key": "productId",      "value": "", "type": "string" },
    { "key": "stockOriginal",  "value": "", "type": "string" },
    { "key": "orderId_us1",    "value": "", "type": "string" },
    { "key": "paymentId_us1",  "value": "", "type": "string" },
    { "key": "stockAntes_us1", "value": "", "type": "string" },
    { "key": "orderId_us2",    "value": "", "type": "string" },
    { "key": "paymentId_us2",  "value": "", "type": "string" },
    { "key": "orderId_us3a",   "value": "", "type": "string" },
    { "key": "paymentId_us3a", "value": "", "type": "string" },
    { "key": "orderId_us3b",   "value": "", "type": "string" },
    { "key": "paymentId_us3b", "value": "", "type": "string" },
    { "key": "orderId_us3c",   "value": "", "type": "string" },
    { "key": "paymentId_us3c", "value": "", "type": "string" },
    { "key": "orderId_us4",    "value": "", "type": "string" },
    { "key": "orderId_us5",    "value": "", "type": "string" },
    { "key": "paymentId_us5",  "value": "", "type": "string" },
    { "key": "stockAntes_us5", "value": "", "type": "string" },
    { "key": "qty_us1", "value": "2", "type": "string" }
  ],
  "item": [

    {
      "name": "[Setup] Autenticação e Produto Base",
      "description": "Registra usuários de teste, obtém tokens e identifica o produto a ser usado nos cenários.",
      "item": [
        {
          "name": "1. Registrar User A",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste User A\",\n  \"email\": \"cancel_user_a@test.com\",\n  \"password\": \"Senha123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "// Aceita 201 (novo) ou 409 (já existe — ok para re-execuções)",
                "pm.test('Registro OK ou usuário já existe', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "2. Login User A",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cancel_user_a@test.com\",\n  \"password\": \"Senha123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Login User A retorna 200', () => pm.response.to.have.status(200));",
                "",
                "const json = pm.response.json();",
                "pm.test('Response contém accessToken', () => {",
                "  pm.expect(json.data.tokens.accessToken).to.be.a('string');",
                "});",
                "",
                "pm.collectionVariables.set('tokenA', json.data.tokens.accessToken);"
              ]
            }
          }]
        },
        {
          "name": "3. Registrar User B",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste User B\",\n  \"email\": \"cancel_user_b@test.com\",\n  \"password\": \"Senha123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Registro OK ou usuário já existe', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "4. Login User B",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cancel_user_b@test.com\",\n  \"password\": \"Senha123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Login User B retorna 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('tokenB', json.data.tokens.accessToken);"
              ]
            }
          }]
        },
        {
          "name": "5. Registrar Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste Admin\",\n  \"email\": \"cancel_admin@test.com\",\n  \"password\": \"Senha123!\",\n  \"role\": \"ADMIN\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Registro OK ou admin já existe', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6. Login Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cancel_admin@test.com\",\n  \"password\": \"Senha123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Login Admin retorna 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('tokenAdmin', json.data.tokens.accessToken);"
              ]
            }
          }]
        },
        {
          "name": "7. GET /products — capturar productId e estoque",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('GET /products retorna 200', () => pm.response.to.have.status(200));",
                "",
                "const json = pm.response.json();",
                "const products = json.data || json;",
                "",
                "pm.test('Existe ao menos 1 produto ACTIVE com stock >= 5', () => {",
                "  const eligible = products.find(p => p.status === 'ACTIVE' && p.stock >= 5);",
                "  pm.expect(eligible, 'Nenhum produto elegível encontrado — seed o banco com produto ACTIVE stock >= 5').to.exist;",
                "  pm.collectionVariables.set('productId', eligible.id);",
                "  pm.collectionVariables.set('stockOriginal', String(eligible.stock));",
                "});"
              ]
            }
          }]
        }
      ]
    },

    {
      "name": "[US1] Cancelar Pedido PENDING",
      "description": "Cenário principal: usuário cancela seu próprio pedido enquanto ainda está em PENDING.\nValida: 200, order.status CANCELED, payment.status CANCELED, estoque restaurado.",
      "item": [
        {
          "name": "1. Adicionar ao Carrinho (User A)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Adicionar ao carrinho retorna 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        },
        {
          "name": "2. Checkout (User A) — capturar orderId e paymentId",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Checkout retorna 201', () => pm.response.to.have.status(201));",
                "",
                "const json = pm.response.json();",
                "const order = json.data;",
                "",
                "pm.test('Order criado com status PENDING', () => {",
                "  pm.expect(order.status).to.eql('PENDING');",
                "});",
                "",
                "pm.collectionVariables.set('orderId_us1', order.id);",
                "",
                "// payment vem embutido no checkout ou precisamos buscá-lo via GET /orders",
                "if (order.payment && order.payment.id) {",
                "  pm.collectionVariables.set('paymentId_us1', order.payment.id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "3. GET /products/:id — estoque ANTES do cancelamento",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('GET product retorna 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "const product = json.data || json;",
                "pm.collectionVariables.set('stockAntes_us1', String(product.stock));"
              ]
            }
          }]
        },
        {
          "name": "4. ⭐ POST /orders/:id/cancel — TESTE PRINCIPAL",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders/{{orderId_us1}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('[SC-001] Retorna HTTP 200', () => pm.response.to.have.status(200));",
                "",
                "const json = pm.response.json();",
                "const order = json.data;",
                "",
                "pm.test('[SC-001] order.status === CANCELED no body da resposta', () => {",
                "  pm.expect(order.status).to.eql('CANCELED');",
                "});",
                "",
                "pm.test('[FR-008] Response segue padrão { data, meta }', () => {",
                "  pm.expect(json).to.have.property('data');",
                "  pm.expect(json).to.have.property('meta');",
                "  pm.expect(json.meta).to.have.property('timestamp');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "5. GET /orders — verificar payment.status CANCELED",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ]
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('GET /orders retorna 200', () => pm.response.to.have.status(200));",
                "",
                "const json = pm.response.json();",
                "const orders = json.data;",
                "const orderId = pm.collectionVariables.get('orderId_us1');",
                "const order = orders.find(o => o.id === orderId);",
                "",
                "pm.test('[SC-004] payment.status === CANCELED no banco', () => {",
                "  pm.expect(order, 'Pedido não encontrado no GET /orders').to.exist;",
                "  pm.expect(order.payment.status).to.eql('CANCELED');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "6. GET /products/:id — verificar estoque restaurado",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('GET product retorna 200', () => pm.response.to.have.status(200));",
                "",
                "const json = pm.response.json();",
                "const product = json.data || json;",
                "const stockAntes = parseInt(pm.collectionVariables.get('stockAntes_us1'), 10);",
                "const qtyUsada = 2;",
                "",
                "pm.test('[SC-003] Estoque restaurado: stock === stockAntes + qty cancelada', () => {",
                "  pm.expect(product.stock).to.eql(stockAntes + qtyUsada);",
                "});"
              ]
            }
          }]
        }
      ]
    },

